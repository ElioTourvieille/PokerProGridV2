{
  "name": "poker-progrid",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "docker compose up -d && turbo dev",
    "services": "docker compose up -d",
    "services:down": "docker compose down",
    "lint": "turbo lint",
    "test": "turbo test",
    "format": "prettier --write \"**/*.{ts,tsx,md}\""
  },
  "devDependencies": {
    "prettier": "^3.3.3",
    "turbo": "^2.3.3",
    "typescript": "^5.6.3"
  },
  "packageManager": "pnpm@10.28.1",
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "@parcel/watcher",
      "@prisma/engines",
      "@swc/core",
      "msgpackr-extract",
      "msw",
      "prisma",
      "sharp",
      "unrs-resolver"
    ]
  }
}
